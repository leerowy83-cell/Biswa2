# Copy this to .env for local development (never commit .env to git)

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL blank to use SQLite locally
# Set it on Render/Railway to use PostgreSQL
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Superuser created on first deploy
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@in16.ac.ke
DJANGO_SUPERUSER_PASSWORD=admin123

# CSRF — set to your deployed URL e.g. https://biswa-class-manager.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
